{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:data && next dev",
    "build": "npm run build:data && next build",
    "build:data": "npm run build:copy-data && npm run build:search-index && npm run build:image-manifest && npm run build:item-index && npm run build:recipe-index",
    "build:copy-data": "node scripts/copy-sharded-data.mjs",
    "build:search-index": "node scripts/build-search-index.mjs",
    "build:image-manifest": "node scripts/build-image-manifest.mjs",
    "build:item-index": "node scripts/build-item-index.mjs",
    "build:recipe-index": "node scripts/build-recipe-index.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
